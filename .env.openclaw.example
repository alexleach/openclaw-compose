# Copy to .env and edit.

# ---------- Image / runtime ----------
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_TZ=UTC
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Required when binding beyond loopback.
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=replace-me

# ---------- Mounts ----------
# Path to your project repo on the host.
OPENCLAW_PROJECT_DIR=.

# Optional dedicated OpenClaw workspace seed dir from this repository.
OPENCLAW_SEED_DIR=./openclaw

# ---------- Optional host integrations ----------
# Uncomment and wire up if needed.
# OPENCLAW_SSH_DIR=${HOME}/.ssh
# OPENCLAW_CLAUDE_DIR=${HOME}/.claude
# OPENCLAW_CODEX_DIR=${HOME}/.codex

# ---------- Optional model / channel secrets ----------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# DISCORD_BOT_TOKEN=
# TELEGRAM_BOT_TOKEN=
