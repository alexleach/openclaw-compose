# OpenClaw overlay environment
#
# Copy this file to `.env.openclaw` and fill in only the values you use.
# Keep OpenClaw-specific runtime/config separate from your app's own `.env` where possible.

# -----------------------------------------------------------------------------
# Base image and ports
# -----------------------------------------------------------------------------

# Upstream OpenClaw image tag. Pin to a version for reproducibility if preferred.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Gateway HTTP/WebSocket port exposed on the host.
OPENCLAW_GATEWAY_PORT=18789

# Bridge / companion connectivity port exposed on the host.
OPENCLAW_BRIDGE_PORT=18790

# Named Docker volume used for persistent OpenClaw state.
OPENCLAW_STATE_VOLUME=openclaw_state

# -----------------------------------------------------------------------------
# Security / gateway auth
# -----------------------------------------------------------------------------

# Required when the gateway is reachable beyond loopback.
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=replace-me

# Optional insecure mode for private-network WebSocket access.
# Leave unset unless you know you need it.
# OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=

# -----------------------------------------------------------------------------
# Host mount paths
# -----------------------------------------------------------------------------

# Path to the host project that OpenClaw should work against.
# The container mounts this path at `/app`.
OPENCLAW_PROJECT_DIR=.

# Optional seed/config directory from this repository.
# Mounted read-only at `/seed/openclaw`.
OPENCLAW_SEED_DIR=./openclaw

# Optional SSH directory for the SSH-enabled profile.
# Only used by the `openclaw-ssh` service.
# Set explicitly if needed; avoid relying on host-shell expansion here.
# OPENCLAW_SSH_DIR=/home/your-user/.ssh

# -----------------------------------------------------------------------------
# Core model provider auth
# -----------------------------------------------------------------------------
# Set at least one provider if you want OpenClaw to work out of the box.
# Uncomment only what you use.

# OpenAI / Codex / compatible providers
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Gemini / Google
# GEMINI_API_KEY=...
# GOOGLE_API_KEY=...

# Azure OpenAI / Azure AI
# AZUREAI_API_KEY=...
# AZUREAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# Optional OpenAI-compatible base URL for local/self-hosted models.
# Useful when fronting Ollama, LiteLLM, vLLM, or similar.
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# OLLAMA_URL=http://host.docker.internal:11434

# -----------------------------------------------------------------------------
# Optional qmd / local retrieval defaults
# -----------------------------------------------------------------------------
# Enable these only if you actually use qmd in the mounted project.

# QMD_OPENAI=1
# QMD_CHUNK_SIZE_TOKENS=256
# QMD_CHUNK_OVERLAP_RATIO=0.10
# QMD_CHUNK_WINDOW_TOKENS=160
# NODE_LLAMA_CPP_GPU=false

# -----------------------------------------------------------------------------
# Optional speech-related env
# -----------------------------------------------------------------------------
# OpenClaw can auto-detect several audio transcription paths, or you can wire a
# provider / CLI explicitly in `openclaw/openclaw.json`.

# Deepgram transcription
# DEEPGRAM_API_KEY=

# ElevenLabs TTS
# ELEVENLABS_API_KEY=
# XI_API_KEY=

# Whisper / local STT helpers
# WHISPER_CPP_MODEL=/models/ggml-base.en.bin
# SHERPA_ONNX_MODEL_DIR=/models/sherpa-onnx

# -----------------------------------------------------------------------------
# Optional messaging channels
# -----------------------------------------------------------------------------
# Only set the channels you intend to enable in `openclaw/openclaw.json`.

# Discord bot token
# DISCORD_BOT_TOKEN=

# Telegram bot token
# TELEGRAM_BOT_TOKEN=

# Matrix example
# MATRIX_ACCESS_TOKEN=
# MATRIX_HOMESERVER=https://matrix.example.com

# -----------------------------------------------------------------------------
# Misc useful integration env
# -----------------------------------------------------------------------------

# Path to an mcporter config if you use MCP heavily.
# MCPORTER_CONFIG=/home/node/.openclaw/mcporter/mcporter.json
